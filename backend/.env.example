# Backend Settings
APP_NAME="RGCET Help Desk Backend"
ENVIRONMENT="development"
PORT=8000

# Gemini API Settings
# For stable retrieval-only testing, keep USE_GEMINI=false.
USE_GEMINI=false
GEMINI_API_KEY="replace_with_real_key_if_needed"
MODEL_NAME="models/gemini-2.0-flash"
EMBEDDING_MODEL="models/embedding-001"

# Retrieval Settings
TOP_K_RESULTS=4
SIMILARITY_THRESHOLD=0.65

# Vector Store Settings
CHROMA_DB_PATH="./data/vector_store"
